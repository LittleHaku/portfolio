---
import TechPill from "./TechPill.astro";
import Button from "./Button.astro";
import GitHubIcon from "./icons/GitHubIcon.astro";
import LinkIcon from "./icons/LinkIcon.astro";
import VideoIcon from "./icons/VideoIcon.astro";

interface Props {
  title: string;
  description: string;
  techs?: string[];
  screenshotSrc?: string;
  screenshotAlt?: string;
  githubLink?: string;
  liveLink?: string;
  videoLink?: string;
  type?: "Professional" | "Personal";
}

const {
  title,
  description,
  techs = [],
  screenshotSrc,
  screenshotAlt = `${title} screenshot`,
  githubLink,
  liveLink,
  videoLink,
  type = "Personal",
} = Astro.props;

// Define color variants for each project type
const typeClasses =
  type === "Personal"
    ? "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300"
    : "bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300";
---

<article
  class="group relative flex flex-col bg-white/40 dark:bg-zinc-900/30 backdrop-blur-md border border-white/50 dark:border-zinc-700/50 rounded-2xl overflow-hidden
         transform transition-all duration-300 ease-out h-full
         hover:scale-[1.02] hover:shadow-[0_8px_30px_rgba(0,0,0,0.12)] hover:bg-white/60 dark:hover:bg-zinc-900/50 dark:shadow-none"
>
  {
    screenshotSrc && (
      <img
        src={screenshotSrc}
        alt={screenshotAlt}
        loading="lazy"
        decoding="async"
        class="w-full aspect-[16/9] object-cover object-top group-hover:scale-105 transition-transform duration-300"
      />
    )
  }

  <div class="flex flex-col flex-grow p-4 md:p-5">
    <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
      <h3 class="max-w-[18ch] font-serif text-xl leading-tight text-zinc-900 dark:text-zinc-50">
        {title}
      </h3>

      <span
        class={`w-fit rounded-md px-2.5 py-1 text-[10px] font-mono uppercase tracking-widest ${typeClasses}`}
      >
        {type}
      </span>
    </div>

    <p
      class="mb-3 flex-grow text-base leading-6 text-zinc-700 dark:text-zinc-300"
    >
      {description}
    </p>

    {
      techs.length > 0 && (
        <div class="mb-3 flex flex-wrap gap-1.5">
          {techs.map((tech) => (
            <TechPill label={tech} />
          ))}
        </div>
      )
    }

    <div class="mt-auto flex flex-wrap items-center gap-2 pt-1">
      {
          liveLink && (
              <Button href={liveLink} class="min-h-9 min-w-0 gap-1.5 px-3 py-1.5 text-[11px]">
            <LinkIcon class="w-4 h-4" aria-hidden="true" />
            Live
          </Button>
        )
    }
    {
      githubLink && (
        <Button href={githubLink} class="min-h-9 min-w-0 gap-1.5 px-3 py-1.5 text-[11px]">
          <GitHubIcon class="w-4 h-4" aria-hidden="true" />
          GitHub
        </Button>
      )
    }
      {
        videoLink && (
          <Button href={videoLink} class="min-h-9 min-w-0 gap-1.5 px-3 py-1.5 text-[11px]">
            <VideoIcon class="w-4 h-4" aria-hidden="true" />
            Video
          </Button>
        )
      }
    </div>
  </div>
</article>
