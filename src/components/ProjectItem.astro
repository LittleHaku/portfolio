---
import TechPill from "./TechPill.astro";
import Button from "./Button.astro";
import GitHubIcon from "./icons/GitHubIcon.astro";
import LinkIcon from "./icons/LinkIcon.astro";
import VideoIcon from "./icons/VideoIcon.astro";

interface Props {
  title: string;
  description: string;
  techs?: string[];
  screenshotSrc?: string;
  screenshotAlt?: string;
  githubLink?: string;
  liveLink?: string;
  videoLink?: string;
  type?: "Professional" | "Personal";
  featured?: boolean;
}

const {
  title,
  description,
  techs = [],
  screenshotSrc,
  screenshotAlt = `${title} screenshot`,
  githubLink,
  liveLink,
  videoLink,
  type = "Personal",
  featured = false,
} = Astro.props;

// Define color variants for each project type
const typeClasses =
  type === "Personal"
    ? "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300"
    : "bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300";

const articleClass = featured
  ? "grid gap-0 overflow-hidden rounded-[1.75rem] border border-zinc-300/80 bg-white/92 shadow-[0_18px_60px_rgba(15,23,42,0.09)] backdrop-blur-md transition-all duration-300 ease-out dark:border-zinc-700/70 dark:bg-zinc-900/55 dark:shadow-none md:grid-cols-[1.2fr_0.9fr]"
  : "group relative flex h-full flex-col overflow-hidden rounded-2xl border border-zinc-300/70 bg-white/82 backdrop-blur-md transition-all duration-300 ease-out hover:scale-[1.02] hover:bg-white hover:shadow-[0_8px_30px_rgba(15,23,42,0.10)] dark:border-zinc-700/50 dark:bg-zinc-900/30 dark:hover:bg-zinc-900/50 dark:shadow-none";

const imageClass = featured
  ? "h-full w-full bg-zinc-100 object-cover object-top dark:bg-zinc-950 md:min-h-[24rem]"
  : "w-full aspect-[16/9] object-cover object-top transition-transform duration-300 group-hover:scale-105";

const contentClass = featured
  ? "flex flex-col justify-between gap-5 p-5 md:p-8"
  : "flex flex-col flex-grow p-4 md:p-5";

const titleClass = featured
  ? "max-w-[16ch] font-serif text-3xl leading-tight text-zinc-950 dark:text-zinc-50 md:text-4xl"
  : "max-w-[18ch] font-serif text-xl leading-tight text-zinc-900 dark:text-zinc-50";

const descriptionClass = featured
  ? "max-w-xl text-lg leading-8 text-zinc-800 dark:text-zinc-200"
  : "mb-3 flex-grow text-base leading-6 text-zinc-800 dark:text-zinc-300";

const buttonClass = featured
  ? "min-h-11 gap-2 px-4 py-2 text-xs"
  : "min-h-9 min-w-0 gap-1.5 px-3 py-1.5 text-xs md:text-[11px]";
---

<article class={articleClass}>
  {
    screenshotSrc && (
      <img
        src={screenshotSrc}
        alt={screenshotAlt}
        loading="lazy"
        decoding="async"
        class={imageClass}
      />
    )
  }

  <div class={contentClass}>
    <div class="flex flex-col gap-4">
      {
        featured && (
          <p class="text-xs md:text-[11px] font-mono uppercase tracking-[0.3em] text-zinc-500 dark:text-zinc-400">
            Featured Project
          </p>
        )
      }

      <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
      <h3 class={titleClass}>
        {title}
      </h3>

      <span
        class={`w-fit rounded-md px-2.5 py-1 text-[11px] md:text-[10px] font-mono uppercase tracking-widest ${typeClasses}`}
      >
        {type}
      </span>
      </div>

    <p class={descriptionClass}>
      {description}
    </p>
    </div>

    {
      techs.length > 0 && (
        <div class={`flex flex-wrap ${featured ? "gap-2" : "mb-3 gap-1.5"}`}>
          {techs.map((tech) => (
            <TechPill label={tech} />
          ))}
        </div>
      )
    }

    <div class={`flex flex-wrap items-center gap-2 ${featured ? "pt-3" : "mt-auto pt-1"}`}>
      {
          liveLink && (
              <Button href={liveLink} class={buttonClass}>
            <LinkIcon class="w-4 h-4" aria-hidden="true" />
            Live
          </Button>
        )
    }
    {
      githubLink && (
        <Button href={githubLink} class={buttonClass}>
          <GitHubIcon class="w-4 h-4" aria-hidden="true" />
          GitHub
        </Button>
      )
    }
      {
        videoLink && (
          <Button href={videoLink} class={buttonClass}>
            <VideoIcon class="w-4 h-4" aria-hidden="true" />
            Video
          </Button>
        )
      }
    </div>
  </div>
</article>
