---
import ProjectItem from "./ProjectItem.astro";

const PROJECTS: any[] = [
  {
    title: "Obsidian Smart Export",
    description:
    "Open-source Obsidian plugin used by 1.9k+ users to export linked notes into one Markdown document. Built with BFS-based traversal and GitHub Actions release automation.",
    screenshotSrc: "/screenshots/obsidian-smart-export.webp",
    techs: ["TypeScript", "BFS", "Obsidian"],
    liveLink: "https://smart-export.vercel.app/",
    githubLink: "https://github.com/LittleHaku/obsidian-smart-export",
    type: "Personal",
    featured: true,
  },
  {
    title: "TRACER",
    description:
      "Automated chatbot exploration system that extracts functional models and generates reusable test scenarios. Built at UAM for conversational AI testing.",
    techs: ["LangGraph", "NLP", "Python"],
    screenshotSrc: "/screenshots/tracer.webp",
    liveLink: "https://pypi.org/project/chatbot-tracer/",
    githubLink: "https://github.com/Chatbot-TRACER/TRACER",
    type: "Professional",
  },
  {
    title: "Chatbot Dojo",
    description:
      "Full-stack platform that unifies chatbot testing tools in one workflow. Built with React and Django for async processing, persistence, and deployment.",
    techs: ["Django", "React", "Docker", "Celery", "PostgreSQL"],
    screenshotSrc: "/screenshots/chatbot-dojo.webp",
    liveLink: "http://miso.ii.uam.es:8081/",
    videoLink: "https://www.youtube.com/watch?v=dFsbN1FKGVg",
    githubLink: "https://github.com/satori-chatbots/chatbot-dojo",
    type: "Professional",
  },
  {
    title: "Drumscribe AI",
    description:
    "Deep learning project that converts drum audio into General MIDI. Built as a personal audio ML project and later reused for coursework.",
    screenshotSrc: "/screenshots/drumscribe-ai.webp",
    techs: ["PyTorch", "Python", "Deep Learning"],
    githubLink: "https://github.com/LittleHaku/DrumScribe-AI",
    liveLink: "https://docs.google.com/presentation/d/e/2PACX-1vRZMLv54Lwds3XjPzL-EkvlxaNIu4ZqrGLiD8GjuV42B5Cri0M5aMMj-cHX-8UGUVEaHpDuh8Z1HQRC/pub",
    type: "Personal"
  },
  {
    title: "U.D.I.N.",
    description: "Desktop tool for vehicle homologation workflows in Spain that automates official engineering documents. Replaced repetitive manual documentation work with a structured app used professionally.",
    screenshotSrc: "/screenshots/UDIN.webp",
    techs: ["C#", "WPF"],
    type: "Professional",
  },
  {
    title: "Spotify Reviews Sentiment Analysis",
    description: "NLP project that classifies roughly 50k Spotify reviews as positive or negative. Built a custom preprocessing pipeline and trained a TensorFlow bag-of-words classifier.",
    screenshotSrc: "/screenshots/spotify.webp",
    githubLink:"https://github.com/LittleHaku/spotify-reviews-sentiment-analysis",
    techs: ["Python", "TensorFlow", "NLP"],
    type: "Personal"
  }
];

const featuredProject = PROJECTS.find((project) => project.featured);
const secondaryProjects = PROJECTS.filter((project) => !project.featured);
---

<div class="space-y-8">
  {
    featuredProject && (
      <ProjectItem {...featuredProject} featured />
    )
  }

  <div class="grid gap-8 md:grid-cols-2">
    {secondaryProjects.map((project) => (
      <ProjectItem {...project} />
    ))}
  </div>
</div>
