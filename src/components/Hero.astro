---
import Badge from "../components/Badge.astro";
import Button from "../components/Button.astro";
import LinkInline from "../components/LinkInline.astro";
import GitHubIcon from "./icons/GitHubIcon.astro";
import MailIcon from "./icons/MailIcon.astro";
import LinkedInIcon from "./icons/LinkedInIcon.astro";
import PDFIcon from "./icons/PDFIcon.astro";
---

<div class="flex gap-4 mb-4">
  <p class="font-mono text-[11px] uppercase tracking-[0.32em] text-zinc-500 dark:text-zinc-400">
    Madrid, Spain / Open to Relocation
  </p>
</div>

<div class="flex gap-4 mb-4">
  <h1 class="font-serif text-5xl md:text-7xl">IVÁN SOTILLO.</h1>
</div>

<h2 class="font-serif text-balance text-3xl md:text-5xl w-full italic">
  Software Engineer building backend systems and applied AI products
</h2>

<p class="w-full text-zinc-600 font-light text-lg md:text-2xl mt-4 max-w-3xl dark:text-zinc-300 leading-relaxed">
  Building chatbot testing platforms and applied AI tooling at <LinkInline href="https://www.miso.es/"
    >MISO Lab</LinkInline
  >.
</p>

<nav aria-label="Primary actions" class="flex flex-wrap gap-2 mt-8">
  <a href="mailto:ivandelhorno@gmail.com">
    <Badge>
      <MailIcon aria-hidden="true" />
      Open to Work
    </Badge>
  </a>

  <Button href="https://www.github.com/LittleHaku">
    <GitHubIcon aria-hidden="true" />
    GitHub
  </Button>
  <Button href="https://www.linkedin.com/in/ivansotillo/">
    <LinkedInIcon aria-hidden="true" />
    LinkedIn
  </Button>
  <Button href="/documents/CV_Ivan_Sotillo.pdf" download>
    <PDFIcon aria-hidden="true" />
    Download CV
  </Button>
</nav>
