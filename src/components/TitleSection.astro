---
interface Props {
  eyebrow?: string;
  description?: string;
  className?: string;
}

const {
  eyebrow,
  description,
  className = "",
} = Astro.props as Props;
---

<div class={`mb-8 md:mb-10 ${className}`}>
  <div class="mb-5 h-px w-full bg-zinc-200/80 dark:bg-zinc-800/80"></div>

  <div class="grid gap-4 md:grid-cols-[minmax(0,1.25fr)_minmax(18rem,24rem)] md:items-end md:gap-8">
    <div class="space-y-3">
      {
        eyebrow && (
          <p class="font-mono text-[11px] uppercase tracking-[0.28em] text-zinc-500 dark:text-zinc-400">
            {eyebrow}
          </p>
        )
      }

      <h2 class="font-serif text-4xl leading-none tracking-tight text-black dark:text-white md:text-5xl">
        <slot />
      </h2>
    </div>

    {
      description && (
        <p class="max-w-md text-balance text-sm leading-7 text-zinc-600 dark:text-zinc-300 md:justify-self-end md:text-base">
          {description}
        </p>
      )
    }
  </div>
</div>
