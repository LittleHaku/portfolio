---
import Badge from "./Badge.astro";
import Button from "./Button.astro";
import MailIcon from "./icons/MailIcon.astro";
import GitHubIcon from "./icons/GitHubIcon.astro";
import LinkedInIcon from "./icons/LinkedInIcon.astro";
---

<p class="text-zinc-700 dark:text-zinc-300 max-w-2xl text-balance">
  Email is the fastest way to reach me. GitHub and LinkedIn are included below
  for public work, writing, and background.
</p>

{/* quick links */}
<nav aria-label="Contact links" class="flex flex-wrap gap-2 mt-8">
  <a href="mailto:ivandelhorno@gmail.com">
    <Badge>
      <MailIcon aria-hidden="true" />
      Email Me
    </Badge>
  </a>

  <Button href="https://www.github.com/LittleHaku">
    <GitHubIcon aria-hidden="true" />
    GitHub
  </Button>
  <Button href="https://www.linkedin.com/in/ivansotillo/">
    <LinkedInIcon aria-hidden="true" />
    LinkedIn
  </Button>
</nav>
