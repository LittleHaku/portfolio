---
import ExperienceItem from "./ExperienceItem.astro"
const EXPERIENCE = [
  {
    date: "May 2026 - Present",
    title: "Software Engineer, Data & Integrations",
    company: "Gambooza (Madrid, Spain)",
    highlights: [
      "Built and productionized a multi-tenant POS ingestion and reconciliation pipeline using Google Cloud Functions and Firebase Firestore, integrating heterogeneous TPV/POS providers across 18 venues.",
      "Automated weekly data-processing and discrepancy reporting workflows, reducing report preparation from roughly half a workday to ~10 minutes while scaling coverage from 10 to 18 venues.",
      "Designed the POS data model and normalization layer for noisy catalogs of 100-700 products per venue, mapping relevant beer products and taps for dashboards and client-facing reports.",
      "Built reconciliation logic that connects external sales data with product analytics signals to surface operational discrepancies across client venues.",
    ],
    techs: ["Python", "Google Cloud Functions", "Firebase Firestore", "SQL", "Data Ingestion", "Data Processing"],
  },
  {
    date: "Dec. 2024 - Apr. 2026",
    title: "Software Engineer / Research Staff",
    company: "Universidad Autónoma de Madrid - MISO Research Group (Madrid, Spain)",
    highlights: [
      "Built and deployed a full-stack platform that integrates chatbot testing tools into a single workflow using React, Django REST, PostgreSQL, Celery, Docker, and Nginx.",
      "Designed backend workflows for task orchestration, data persistence, and API-based integration across evaluation components.",
      "Developed applied AI tooling with LangGraph and OpenAI APIs to automate chatbot exploration, capability extraction, and reusable test-scenario generation.",
      "Implemented CI/CD and release automation with GitHub Actions, including publishing Python packages to PyPI in a shared pull-request-based codebase.",
      {
        text: "Co-authored and published work on automated exploration of conversational agents for testing.",
        href: "https://doi.org/10.1007/978-3-032-05188-2_14",
        linkLabel: "DOI",
      },
    ],
    link: "https://doi.org/10.1007/978-3-032-05188-2_14",
    techs: ["Python", "LangGraph", "OpenAI API", "Django REST", "PostgreSQL", "React"],
  },
]
---

<ol class="relative">
  {
    EXPERIENCE.map((experience) => (
      <li class="">
        <ExperienceItem {...experience} />
      </li>
    ))
  }
</ol>
