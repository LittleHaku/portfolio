---
import LinkInline from "./LinkInline.astro";
import TechPill from "./TechPill.astro";

interface Props {
  title: string;
  venue: string; // e.g. "ICTSS 2025", "Journal of Systems and Software"
  date: string; // e.g. "Nov 2025"
  description?: string; // short abstract / note
  link?: string; // paper / doi / arxiv / pdf
  tags?: string[]; // e.g. ["LLM", "Testing", "Chatbots"]
}

const {
  title,
  venue,
  date,
  description,
  link,
  tags = [],
  type = "Conference",
} = Astro.props;

---

<div
  class="relative mx-12 pb-12 grid
         before:absolute before:left-[-35px] before:block before:h-full
         before:border-l before:border-zinc-200/80
         dark:before:border-zinc-700/40
         md:grid-cols-5 md:gap-10 md:space-x-4"
>
  {/* left column: metadata */}
  <div class="relative pb-12 md:col-span-2">
    <div class="sticky top-0">
      {/* timeline node */}
      <span
        class="absolute -left-[43px] top-6 -translate-y-1/2
               inline-flex h-4 w-4 items-center justify-center
               rounded-md bg-white/40 dark:bg-zinc-900/30
               backdrop-blur-sm border border-zinc-200/50 dark:border-zinc-700/50 shadow-sm"
      >
        <span class="h-1.5 w-1.5 rounded-sm bg-zinc-800 dark:bg-zinc-200"></span>
      </span>

      <h3
        class="font-serif text-lg md:text-xl tracking-tight text-zinc-900 dark:text-zinc-50"
      >
        {title}
      </h3>

      <div class="mt-2 flex items-center gap-2">
        <p
          class="text-[10px] font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400"
        >
          {venue}
        </p>
      </div>

      <time class="mt-1 block text-[10px] font-mono tracking-widest uppercase text-zinc-400 dark:text-zinc-500">
        {date}
      </time>
    </div>
  </div>

  {/* right column: abstract + tags + link */}
  <div
    class="relative flex flex-col gap-3 pb-4 text-zinc-600 dark:text-zinc-200 md:col-span-3 leading-relaxed"
  >
    {description && <p>{description}</p>}

    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-1">
          {tags.map((tag) => (
            <TechPill label={tag} />
          ))}
        </div>
      )
    }

    {
      link && (
        <LinkInline href={link}>
          Read publication
          <svg
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            class="w-4 h-4"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path stroke="none" d="M0 0h24v24H0z" />
            <path d="M9 6l6 6l-6 6" />
          </svg>
        </LinkInline>
      )
    }
  </div>
</div>
