---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  date?: string; // optional, some awards don't need it
}

const { title, subtitle, description, date } = Astro.props;
---

<div
  class="relative mx-12 pb-10 grid
         before:absolute before:left-[-35px] before:block before:h-full
         before:border-l before:border-zinc-200/80
         dark:before:border-zinc-700/40
         md:grid-cols-5 md:gap-10 md:space-x-4"
>
  {/* left column: title/meta */}
  <div class="relative pb-6 md:col-span-2">
    <div class="sticky top-0">
      {/* timeline node */}
      <span
        class="absolute -left-[43px] top-3
               inline-flex h-4 w-4 items-center justify-center
               rounded-md bg-white/88 dark:bg-zinc-900/30
               backdrop-blur-sm border border-zinc-300/70 dark:border-zinc-700/50 shadow-[0_4px_14px_rgba(15,23,42,0.05)]"
      >
        <span class="h-1.5 w-1.5 rounded-sm bg-zinc-800 dark:bg-zinc-200"></span>
      </span>

      <h3 class="font-serif text-lg md:text-xl tracking-tight text-zinc-900 dark:text-zinc-50">
        {title}
      </h3>

      {subtitle && (
        <p class="mt-2 text-[11px] md:text-[10px] font-mono uppercase tracking-widest text-zinc-600 dark:text-zinc-400">
          {subtitle}
        </p>
      )}

      {date && (
        <p class="mt-1 text-[11px] md:text-[10px] font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-500">
          {date}
        </p>
      )}
    </div>
  </div>

  {/* right column: description */}
  <div class="relative md:col-span-3 text-zinc-700 dark:text-zinc-200 leading-relaxed">
    {description && <p>{description}</p>}
  </div>
</div>
