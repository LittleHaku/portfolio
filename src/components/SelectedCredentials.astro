---
import LinkInline from "./LinkInline.astro";
import TechPill from "./TechPill.astro";
import { ACHIEVEMENTS, EDUCATION, PUBLICATIONS } from "../data/credentials";

const selectedEducation = EDUCATION.filter((item) =>
  ["MSc Data Science", "BSc Computer Science Engineering (Bilingual)"].includes(item.degree),
);

const additionalEducation = EDUCATION.filter((item) =>
  ["Spring School", "Exchange Program"].includes(item.degree),
);
---

<div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
  <article class="rounded-[1.5rem] border border-zinc-300/75 bg-white/86 p-5 shadow-[0_18px_48px_rgba(15,23,42,0.06)] backdrop-blur-md dark:border-zinc-700/60 dark:bg-zinc-900/35 dark:shadow-none md:p-6">
    <div class="mb-5 flex items-center justify-between gap-4">
      <h3 class="font-serif text-2xl text-zinc-950 dark:text-zinc-50">Education</h3>
      <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-zinc-500 dark:text-zinc-400">
        Selected
      </p>
    </div>

    <div class="space-y-5">
      {selectedEducation.map((item) => (
        <div class="border-t border-zinc-200/80 pt-5 first:border-t-0 first:pt-0 dark:border-zinc-700/50">
          <div class="flex flex-col gap-1 md:flex-row md:items-start md:justify-between">
            <div>
              <h4 class="font-serif text-xl leading-tight text-zinc-950 dark:text-zinc-50">{item.degree}</h4>
              <p class="mt-1 text-sm text-zinc-700 dark:text-zinc-300">{item.institution}</p>
            </div>
            <p class="shrink-0 whitespace-nowrap text-[11px] font-mono uppercase tracking-[0.24em] text-zinc-500 dark:text-zinc-400 md:pl-4 md:text-right">
              {item.date}
            </p>
          </div>

          <div class="mt-3 flex flex-wrap gap-2">
            {item.courses?.map((course) => (
              <TechPill label={course} />
            ))}
          </div>

          <p class="mt-3 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
            {item.description}
          </p>

          {
            item.link && (
              <div class="mt-3">
                <LinkInline href={item.link}>{item.linkDescription ?? "Learn more"}</LinkInline>
              </div>
            )
          }
        </div>
      ))}
    </div>

    {
      additionalEducation.length > 0 && (
        <div class="mt-6 border-t border-zinc-200/80 pt-5 dark:border-zinc-700/50">
          <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-zinc-500 dark:text-zinc-400">
            Additional Academic Experience
          </p>

          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {additionalEducation.map((item) => (
              <div class="rounded-2xl border border-zinc-200/80 bg-zinc-50/80 p-4 dark:border-zinc-700/50 dark:bg-zinc-950/30">
                <h4 class="font-serif text-lg leading-tight text-zinc-950 dark:text-zinc-50">{item.degree}</h4>
                <p class="mt-1 text-sm text-zinc-700 dark:text-zinc-300">{item.institution}</p>
                <p class="mt-2 shrink-0 whitespace-nowrap text-[11px] font-mono uppercase tracking-[0.24em] text-zinc-500 dark:text-zinc-400">
                  {item.date}
                </p>

                {
                  item.courses && item.courses.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {item.courses.map((course) => (
                        <TechPill label={course} />
                      ))}
                    </div>
                  )
                }

                <p class="mt-3 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
                  {item.description}
                </p>

                {
                  item.link && (
                    <div class="mt-3">
                      <LinkInline href={item.link}>{item.linkDescription ?? "Learn more"}</LinkInline>
                    </div>
                  )
                }
              </div>
            ))}
          </div>
        </div>
      )
    }
  </article>

  <div class="grid gap-6">
    <article class="rounded-[1.5rem] border border-zinc-300/75 bg-white/86 p-5 shadow-[0_18px_48px_rgba(15,23,42,0.06)] backdrop-blur-md dark:border-zinc-700/60 dark:bg-zinc-900/35 dark:shadow-none md:p-6">
      <div class="mb-4 flex items-center justify-between gap-4">
        <h3 class="font-serif text-2xl text-zinc-950 dark:text-zinc-50">Publication</h3>
        <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-zinc-500 dark:text-zinc-400">
          Research
        </p>
      </div>

      {PUBLICATIONS.map((publication) => (
        <div class="space-y-3">
          <div>
            <h4 class="font-serif text-xl leading-tight text-zinc-950 dark:text-zinc-50">{publication.title}</h4>
            <p class="mt-1 text-sm text-zinc-700 dark:text-zinc-300">{publication.venue}</p>
            <p class="mt-1 shrink-0 whitespace-nowrap text-[11px] font-mono uppercase tracking-[0.24em] text-zinc-500 dark:text-zinc-400">
              {publication.date}
            </p>
          </div>

          <p class="text-sm leading-6 text-zinc-700 dark:text-zinc-300">{publication.description}</p>

          <div class="flex flex-wrap gap-2">
            {publication.tags?.map((tag) => (
              <TechPill label={tag} />
            ))}
          </div>

          <LinkInline href={publication.link}>Read publication</LinkInline>
        </div>
      ))}
    </article>

    <article class="rounded-[1.5rem] border border-zinc-300/75 bg-white/86 p-5 shadow-[0_18px_48px_rgba(15,23,42,0.06)] backdrop-blur-md dark:border-zinc-700/60 dark:bg-zinc-900/35 dark:shadow-none md:p-6">
      <div class="mb-4 flex items-center justify-between gap-4">
        <h3 class="font-serif text-2xl text-zinc-950 dark:text-zinc-50">Achievements</h3>
        <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-zinc-500 dark:text-zinc-400">
          Awards
        </p>
      </div>

      <div class="space-y-4">
        {ACHIEVEMENTS.map((achievement) => (
          <div class="border-t border-zinc-200/80 pt-4 first:border-t-0 first:pt-0 dark:border-zinc-700/50">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h4 class="font-serif text-lg leading-tight text-zinc-950 dark:text-zinc-50">
                  {achievement.title}
                </h4>
                <p class="mt-1 text-sm text-zinc-700 dark:text-zinc-300">{achievement.subtitle}</p>
              </div>
              {
                achievement.date && (
                  <p class="shrink-0 whitespace-nowrap text-[11px] font-mono uppercase tracking-[0.24em] text-zinc-500 dark:text-zinc-400 sm:pl-4 sm:text-right">
                    {achievement.date}
                  </p>
                )
              }
            </div>

            {
              achievement.description && (
                <p class="mt-2 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
                  {achievement.description}
                </p>
              )
            }

            {
              achievement.items && (
                <ul class="mt-2 space-y-1 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
                  {achievement.items.map((item) => (
                    <li class="flex items-start gap-2">
                      <span class="mt-[0.45rem] h-1.5 w-1.5 rounded-full bg-zinc-500 dark:bg-zinc-400"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              )
            }
          </div>
        ))}
      </div>
    </article>
  </div>
</div>
