---
interface Props {
  label: string
}

const { label } = Astro.props
---

<span
  class="inline-flex items-center rounded-md border
         border-zinc-300/70 dark:border-zinc-700/50
         bg-white/88 dark:bg-zinc-900/30 backdrop-blur-sm shadow-[0_4px_16px_rgba(15,23,42,0.04)]
         text-zinc-800 dark:text-zinc-100
         px-3 py-1 text-[11px] md:text-[10px] font-mono tracking-widest uppercase whitespace-nowrap"
>
  {label}
</span>
