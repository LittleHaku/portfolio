---
interface Props {
  label: string
}

const { label } = Astro.props
---

<span
  class="inline-flex items-center rounded-md border
         border-zinc-200/50 dark:border-zinc-700/50
         bg-white/40 dark:bg-zinc-900/30 backdrop-blur-sm shadow-sm
         text-zinc-900 dark:text-zinc-100
         px-3 py-1 text-[10px] font-mono tracking-widest uppercase"
>
  {label}
</span>
