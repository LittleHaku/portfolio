---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionContainer from '../components/SectionContainer.astro';
import TitleSection from '../components/TitleSection.astro';
import Experience from '../components/Experience.astro';
import Particles from '../components/Particles.astro';
import Projects from '../components/Projects.astro';
import ContactMe from '../components/ContactMe.astro';
import SelectedCredentials from '../components/SelectedCredentials.astro';
---

<Layout
  title="Iván Sotillo - Software Engineer | Backend, Developer Tools, Applied AI"
  description="Software engineer building backend systems, developer tools, and applied AI products. Experience across platform engineering, workflow automation, and chatbot testing."
  siteUrl="https://ivansotillo.com"
  ogImageUrl="og.png"
  ogImageTwitter="og-twitter.png"
>
  <Particles />
  <main id="main-content" tabindex="-1" class="px-4 focus:outline-none">
    <div class="flex flex-col space-y-8">
      <SectionContainer class="mt-20 md:mt-48">
        <Hero />
      </SectionContainer>

      <SectionContainer id="projects">
        <TitleSection>Projects</TitleSection>
        <Projects />
      </SectionContainer>

      <SectionContainer id="experience">
        <TitleSection>Experience</TitleSection>
        <Experience />
      </SectionContainer>

      <SectionContainer id="credentials">
        <TitleSection>Selected Credentials</TitleSection>
        <SelectedCredentials />
      </SectionContainer>

      <SectionContainer id="contact-me">
        <TitleSection>Let's Connect</TitleSection>
        <ContactMe />
      </SectionContainer>
    </div>
  </main>
</Layout>
